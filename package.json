{
  "name": "d3.js-data-viz",
  "version": "0.1.0",
  "description": "A layered, declarative data-visualization toolkit built on Vega-Lite.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaveManning/D3.js-data-viz.git"
  },
  "keywords": [
    "vega-lite",
    "d3.js",
    "data",
    "visualization",
    "dashboard",
    "declarative"
  ],
  "author": "dave manning",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/DaveManning/D3.js-data-viz/issues"
  },
  "homepage": "https://github.com/DaveManning/D3.js-data-viz#readme",
  "dependencies": {
    "vega": "^5.30.0",
    "vega-embed": "^6.29.0",
    "vega-lite": "^5.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
